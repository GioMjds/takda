generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Tenancy
// -----------------------------------------------------------------------------

/// One deployment of Takda. For v1 this is a 1:1 with the running app; later
/// it becomes the "organization" boundary for SaaS multi-tenancy.
model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique // e.g. "acme" → acme.takda.app
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  businesses  Business[]
  idempotency IdempotencyKey[]
  auditLogs   AuditLog[]
}

// -----------------------------------------------------------------------------
// Identity
// -----------------------------------------------------------------------------

/// An owner / staff user. Belongs to one tenant, can own/operate many
/// businesses. Auth is JWT; passwords are bcrypt-hashed here.
model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  name         String
  role         UserRole @default(OWNER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships   Membership[]
  refreshTokens RefreshToken[]
  staffInvites  StaffInvite[]  @relation("InvitedBy")

  @@unique([tenantId, email])
  @@index([tenantId])
}

/// Join table: which users work at which business and in what role.
model Membership {
  id         String         @id @default(cuid())
  userId     String
  businessId String
  role       MembershipRole @default(STAFF)
  createdAt  DateTime       @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([businessId])
}

/// Hashed refresh tokens for JWT rotation. The JWT itself is stateless;
/// the refresh token is the durable credential.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// -----------------------------------------------------------------------------
// Business
// -----------------------------------------------------------------------------

/// A single walk-in business inside a tenant. The QR code points here.
/// The owner configures services, hours, and capacity on this entity.
model Business {
  id        String   @id @default(cuid())
  tenantId  String
  slug      String // unique per tenant; used in URLs
  name      String
  timezone  String   @default("Asia/Manila")
  // Address & contact
  address   String?
  phone     String?
  settings  Json     @default("{}")
  // Status
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services     Service[]
  bookings     Booking[]
  memberships  Membership[]
  reminders    Reminder[]
  messages     Message[]
  overrides    DayOverride[]
  branched     Branch[]
  staffInvites StaffInvite[]
  workingHours WorkingHours[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

/// Per-business hours & day-level metadata (e.g. "closed on holidays").
/// Kept tiny here; most hour-of-operation info lives on the Service
/// because services can have different hours (e.g. lunch-only service).
model DayOverride {
  id               String   @id @default(cuid())
  businessId       String
  /// Calendar date in the business's timezone, midnight UTC equivalent.
  /// e.g. 2026-07-18 — a `date` not a `timestamp`.
  date             DateTime @db.Date
  isClosed         Boolean  @default(false)
  /// Optional override of opening / closing times in HH:mm (business TZ).
  openTime         String?
  closeTime        String?
  /// Max total bookings for the day, across all services. NULL = no cap.
  capacityOverride Int?
  note             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date])
  @@index([businessId, date])
}

// -----------------------------------------------------------------------------
// Service
// -----------------------------------------------------------------------------

/// A bookable offering of a business (e.g. "Haircut", "Stall #3 pickup").
model Service {
  id              String   @id @default(cuid())
  businessId      String
  slug            String
  name            String
  description     String?
  /// Duration of one slot in minutes (e.g. 5 = "1 slot every 5 min").
  durationMin     Int
  /// Maximum concurrent bookings for any one slot start (usually 1).
  capacityPerSlot Int      @default(1)
  /// Total bookings allowed for the day. NULL = unlimited.
  dailyCapacity   Int?
  /// Open / close in HH:mm business-local. Slot generation only emits
  /// times within [openTime, closeTime - durationMin].
  openTime        String
  closeTime       String
  /// Days of the week the service is offered. Bitmask: Sun=1, Mon=2, ... Sat=64.
  /// (Kept as Int for portability; helper in shared package interprets it.)
  daysOfWeekMask  Int      @default(127)
  branchId        String?
  branch          Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  slots    Booking[]

  @@unique([businessId, slug])
  @@index([businessId])
}

// -----------------------------------------------------------------------------
// Bookings
// -----------------------------------------------------------------------------

/// A customer's reservation of one slot for a service at a time.
/// Status flows: pending → confirmed → serving → completed, with
/// (serving | confirmed) → no_show and (pending | confirmed) → cancelled.
/// Bookings are never deleted — terminal states are the audit trail.
model Booking {
  id             String        @id @default(cuid())
  tenantId       String
  businessId     String
  serviceId      String
  /// slotStart is the canonical key for queue ordering.
  /// Always UTC; web formats to business TZ.
  slotStart      DateTime
  /// Human-readable, daily-resetting, monotonic-per-business queue number.
  /// Assigned atomically at creation via the QueueCounter row. Nullable so
  /// pre-existing bookings (and any create path that predates numbering)
  /// remain valid; new bookings always receive one.
  ticketNumber   Int?
  /// Customer details — captured at booking time, not normalized into a
  /// "Customer" table in v1 (walk-in businesses don't have repeat logins).
  customerName   String
  customerPhone  String
  /// Optional notes from the customer ("please use the back entrance").
  notes          String?
  /// Where this booking came from. Walk-ins are added by the owner.
  source         BookingSource @default(ONLINE)
  status         BookingStatus @default(PENDING)
  /// Queue prioritization tier. Higher-priority tiers sort ahead of lower
  /// ones at the same slotStart. See PriorityTier.
  priorityTier   PriorityTier  @default(STANDARD)
  /// Idempotency key used at creation time, if any. Indexed for support
  /// lookups ("did the customer's retry actually book?").
  idempotencyKey String?
  /// When the owner marked this booking as checked_in / no_show / etc.
  resolvedAt     DateTime?
  /// When the booking was called to the counter (status → SERVING).
  servingAt      DateTime?
  /// Number of times the owner has re-announced this booking while serving.
  recallCount    Int           @default(0)
  /// When the customer was fully served (status → COMPLETED). Terminal.
  completedAt    DateTime?
  /// When the booking was cancelled (status → CANCELLED). Terminal.
  cancelledAt    DateTime?
  /// Who initiated the cancellation. NULL unless status is CANCELLED.
  cancelledBy    CancelledBy?
  branchId       String?
  branch         Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  business  Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service   Service    @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  reminders Reminder[]
  messages  Message[]

  /// Hard rule from AGENTS.md §8: no two confirmed bookings for the same
  /// service at the exact same slotStart. This is the database-level guard
  /// the booking transaction relies on (in addition to capacityPerSlot
  /// for >1 concurrency).
  @@unique([serviceId, slotStart, customerPhone], name: "service_slot_phone_unique")
  @@index([businessId, slotStart])
  @@index([businessId, status, slotStart])
  @@index([businessId, status, completedAt])
  @@index([customerPhone])
  @@index([tenantId])
}

/// Per-business, per-day monotonic counter backing Booking.ticketNumber.
model QueueCounter {
  id           String   @id @default(cuid())
  businessId   String
  /// Local calendar date in the business's timezone (midnight-anchored).
  businessDate DateTime @db.Date
  /// Last issued ticket number for this business/day. Next issue is +1.
  lastNumber   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([businessId, businessDate], name: "business_date_unique")
  @@index([businessId])
}

// -----------------------------------------------------------------------------
// Notifications
// -----------------------------------------------------------------------------

/// A scheduled reminder tied to a booking.
model Reminder {
  id          String         @id @default(cuid())
  bookingId   String
  businessId  String
  /// e.g. T-60, T-10, NO_SHOW_FOLLOWUP
  kind        ReminderKind
  /// When the job is scheduled to fire.
  scheduledAt DateTime
  /// BullMQ jobId — used to de-dupe (a re-enqueue with the same jobId is a no-op).
  jobId       String         @unique
  status      ReminderStatus @default(SCHEDULED)
  /// When the worker actually sent the SMS.
  sentAt      DateTime?
  /// When a terminal failure happened.
  failedAt    DateTime?
  /// Last error message, for the audit log.
  error       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  /// Idempotency: a given booking may have at most one reminder of a kind.
  /// This is the "natural key" the worker checks before enqueuing.
  @@unique([bookingId, kind], name: "booking_kind_unique")
  @@index([businessId, scheduledAt])
  @@index([status, scheduledAt])
}

/// Audit log of every SMS the system sends.
model Message {
  id                String        @id @default(cuid())
  tenantId          String
  businessId        String
  bookingId         String?
  /// E.g. +639171234567. E.164 normalized.
  toPhone           String
  /// Stable template id from NotificationsService (e.g. "booking.confirmed").
  templateId        String
  /// Snapshot of variables passed to the template, for replay / audit.
  vars              Json
  /// Rendered body, captured at send time.
  body              String
  /// Provider-side message id (Semaphore / Twilio), for delivery status webhooks.
  providerMessageId String?
  status            MessageStatus @default(PENDING)
  error             String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
  @@index([bookingId])
  @@index([providerMessageId])
  @@index([status])
}

// -----------------------------------------------------------------------------
// Idempotency
// -----------------------------------------------------------------------------

/// Persisted response for every `Idempotency-Key`.
/// A retry with the same key returns the same body — we
/// never paper over with a synthetic 200.
model IdempotencyKey {
  id             String   @id @default(cuid())
  tenantId       String
  /// Client-supplied key.
  key            String
  /// Request fingerprint (method + path + body hash) so a reused key with
  /// a *different* request body is rejected with IDEMPOTENCY_KEY_REUSED.
  requestHash    String
  /// HTTP status we returned the first time.
  responseStatus Int
  /// Cached response body, JSON-serialized.
  responseBody   Json
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([expiresAt])
}

// -----------------------------------------------------------------------------
// Observability
// -----------------------------------------------------------------------------

/// Append-only audit log of meaningful business events ("booking created",
/// "booking cancelled", "walk-in added").
model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  /// Free-form event name, e.g. "booking.created".
  event       String
  /// Subject type + id, polymorphic. e.g. ("booking", "ckxyz").
  subjectType String
  subjectId   String
  /// Actor — usually a User id; for customer actions, the booking id.
  actorId     String?
  /// Correlation id propagated from the request.
  requestId   String?
  /// Free-form JSON payload for the event.
  payload     Json
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, event, createdAt])
  @@index([subjectType, subjectId])
}

/// A physical location of a business. Bookings and services can scope to a branch.
model Branch {
  id         String   @id @default(cuid())
  businessId String
  name       String
  address    String?
  phone      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings Booking[]
  services Service[]

  @@unique([businessId, name])
  @@index([businessId])
}

/// A pending invitation for a new staff user to join a business. The
model StaffInvite {
  id          String         @id @default(cuid())
  businessId  String
  email       String
  role        MembershipRole
  tokenHash   String         @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime       @default(now())

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invitedBy User     @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([businessId, email])
  @@index([expiresAt])
}

/// A business's working hours, for display in the storefront and for slot generation.
model WorkingHours {
  id         String  @id @default(cuid())
  businessId String
  dayOfWeek  Int
  openTime   String
  closeTime  String
  isClosed   Boolean @default(false)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum UserRole {
  OWNER
  ADMIN
  STAFF
  MANAGER
}

enum MembershipRole {
  OWNER
  MANAGER
  STAFF
}

enum BookingStatus {
  /// Created, awaiting SMS confirmation.
  PENDING
  /// Customer's slot is locked in.
  CONFIRMED
  /// Owner marked the customer as arrived (legacy manual check-in).
  CHECKED_IN
  /// Called to the counter and currently being served (head of queue).
  SERVING
  /// Customer has been fully served. Terminal.
  COMPLETED
  /// Customer didn't show up. Terminal.
  NO_SHOW
  /// Customer or owner cancelled before slot. Terminal.
  CANCELLED
}

/// Queue prioritization tiers, highest priority first. Ordering in the
/// queue sorts by this tier (rank) before slotStart. Extensible: append
/// new tiers at the end and update the shared rank helper.
enum PriorityTier {
  VIP
  PREGNANT
  PWD
  SENIOR
  STANDARD
}

/// Who initiated a booking cancellation, for audit and messaging.
enum CancelledBy {
  CUSTOMER
  OWNER
  SYSTEM
}

enum BookingSource {
  ONLINE // public booking flow
  WALK_IN // added by the owner at the storefront
  STAFF // staff pre-booked for a known customer
  IMPORT // migrated from a previous system (v1: unused)
}

enum ReminderKind {
  T_60 // 60 min before slot
  T_10 // 10 min before slot
  NO_SHOW_FOLLOWUP // sent X min after a missed slot
}

enum ReminderStatus {
  SCHEDULED
  SENT
  FAILED
  CANCELLED
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  UNDELIVERED
}
