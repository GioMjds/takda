// Template for `apps/api/.env`. Copy to `.env` and fill in real values.
// Never commit `.env` (see `prisma/.gitignore` and root `.gitignore`).

NODE_ENV=development
PORT=3000

# Postgres. The `adapter-pg` driver reads this URL directly.
DATABASE_URL="postgresql://takda:takda@localhost:5432/takda?schema=public"

# Redis — required for BullMQ. Optional in `development` only if you
# also comment out the reminder workers.
# REDIS_URL="redis://localhost:6379"

# Auth — generate a 32+ char random string for JWT_SECRET.
JWT_SECRET="dev-secret-change-me-to-a-real-32-char-value"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# SMS — pick one. In `test`/`development` these can be empty stubs.
SMS_PROVIDER=semaphore
# SMS_API_KEY=

# Comma-separated list of origins allowed by CORS.
CORS_ORIGINS=http://localhost:3001
